# Database
POSTGRES_PASSWORD=generate-a-strong-db-password
DATABASE_URL=postgresql://ampm:${POSTGRES_PASSWORD}@localhost:5432/ampm?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — generate strong random values (e.g. `openssl rand -hex 32`) and keep them secret.
# The server refuses to start if either is missing.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI API Keys
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-api-token

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Worker
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
