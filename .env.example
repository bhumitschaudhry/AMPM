# Database
POSTGRES_PASSWORD=generate-a-strong-db-password
# Local Docker Compose default. For Neon, use the pooled connection string and
# include sslmode=require, for example: postgresql://...neon.tech/...?...&sslmode=require
DATABASE_URL=postgresql://ampm:${POSTGRES_PASSWORD}@localhost:5432/ampm?schema=public

# Redis
# Upstash provides this as a rediss:// URL. Use redis://localhost:6379 locally.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — generate strong random values (e.g. `openssl rand -hex 32`) and keep them secret.
# The server refuses to start if either is missing.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI API Keys
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-api-token

# Google OAuth (server-side verification for /api/auth/google)
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 as an Authorized JavaScript origin.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
# Get Account ID from: https://dash.cloudflare.com/ → R2 Object Storage
# Create API token at: https://dash.cloudflare.com/ → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=ampm-uploads

# File Upload
MAX_FILE_SIZE_MB=5

# Worker
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Client (Cloudflare Pages build)
# Use the deployed API origin plus /api, e.g. https://api.example.com/api.
VITE_API_URL=/api

# Google OAuth client ID exposed to the browser (same value as GOOGLE_CLIENT_ID above).
VITE_GOOGLE_CLIENT_ID=

# SigNoz / OpenTelemetry Monitoring
OTEL_SERVICE_NAME=ampm-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SDK_DISABLED=false

# Queue depth metrics
# Polls imageQueue.getJobCounts() and exports the result as ampm.queue.depth.
# Set QUEUE_DEPTH_METRICS_ENABLED=false to disable without code changes.
QUEUE_DEPTH_METRICS_ENABLED=true
QUEUE_DEPTH_POLL_INTERVAL_MS=10000

